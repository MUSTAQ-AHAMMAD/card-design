generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  password         String
  firstName        String
  lastName         String
  role             String            @default("EMPLOYEE")
  avatar           String?
  isActive         Boolean           @default(true)
  resetToken       String?
  resetTokenExpiry DateTime?
  deletedAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  refreshTokens    RefreshToken[]
  templates        Template[]
  giftCards        GiftCard[]
  emailLogs        EmailLog[]
  roles            UserRole[]
  activityLogs     ActivityLog[]     @relation("UserActivityLogs")
  templateVersions TemplateVersion[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Template {
  id          String            @id @default(cuid())
  name        String
  category    String
  designData  String
  thumbnail   String?
  usageCount  Int               @default(0)
  isActive    Boolean           @default(true)
  deletedAt   DateTime?
  createdById String
  createdBy   User              @relation(fields: [createdById], references: [id])
  brandId     String?
  brand       Brand?            @relation("BrandTemplates", fields: [brandId], references: [id], onDelete: SetNull)
  giftCards   GiftCard[]
  versions    TemplateVersion[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model GiftCard {
  id             String     @id @default(cuid())
  templateId     String?
  template       Template?  @relation(fields: [templateId], references: [id])
  employeeId     String
  employee       User       @relation(fields: [employeeId], references: [id])
  customizations String
  amount         Float
  occasion       String
  message        String?
  recipientEmail String?
  recipientName  String?
  status         String     @default("DRAFT")
  sentAt         DateTime?
  scheduledAt    DateTime?
  deletedAt      DateTime?
  emailLogs      EmailLog[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model EmailTemplate {
  id        String    @id @default(cuid())
  name      String
  subject   String
  body      String
  variables String    @default("[]")
  isActive  Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model EmailLog {
  id         String    @id @default(cuid())
  giftCardId String?
  giftCard   GiftCard? @relation(fields: [giftCardId], references: [id])
  userId     String?
  user       User?     @relation(fields: [userId], references: [id])
  recipient  String
  subject    String
  status     String    @default("PENDING")
  error      String?
  sentAt     DateTime?
  createdAt  DateTime  @default(now())
}

model Brand {
  id           String        @id @default(cuid())
  name         String        @unique
  logoUrl      String?
  primaryColor String        @default("#3b82f6")
  secondaryColor String?
  description  String?
  website      String?
  isActive     Boolean       @default(true)
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  assets       BrandAsset[]
  templates    Template[]    @relation("BrandTemplates")
}

model BrandAsset {
  id          String    @id @default(cuid())
  brandId     String
  brand       Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  name        String
  assetType   String    // 'logo', 'icon', 'banner', 'image', 'font'
  fileUrl     String
  mimeType    String?
  fileSize    Int?
  width       Int?
  height      Int?
  metadata    String?   // JSON string for additional properties
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model TemplateVersion {
  id          String    @id @default(cuid())
  templateId  String
  template    Template  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  version     Int
  designData  String
  thumbnail   String?
  changelog   String?
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
}

model EmployeeCache {
  id               String    @id @default(cuid())
  email            String    @unique
  firstName        String
  lastName         String
  displayName      String?
  jobTitle         String?
  department       String?
  officeLocation   String?
  mobilePhone      String?
  businessPhones   String?   // JSON array
  thumbnailPhoto   String?
  metadata         String?   // JSON string for additional Outlook data
  lastSyncedAt     DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Permission {
  id          String           @id @default(cuid())
  name        String           @unique  // e.g., 'create:template', 'delete:user', 'view:analytics'
  description String?
  category    String           // e.g., 'template', 'user', 'gift-card', 'analytics'
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique  // e.g., 'admin', 'manager', 'employee'
  description String?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  users       UserRole[]
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([roleId, permissionId])
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
}

model ActivityLog {
  id          String    @id @default(cuid())
  userId      String?
  user        User?     @relation("UserActivityLogs", fields: [userId], references: [id], onDelete: SetNull)
  action      String    // e.g., 'CREATE', 'UPDATE', 'DELETE', 'VIEW', 'LOGIN'
  entityType  String    // e.g., 'user', 'template', 'gift-card', 'brand'
  entityId    String?
  description String?
  metadata    String?   // JSON string for additional context
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}
